
{
  "scripts": {
    "test": "jest --reporters=jest-junit",
    "build": "echo \"Dummy build script for Autocode\"",
    "compile": "sass src/styles/style.scss src/dist/style.css",
    "prefix": "npx postcss src/dist/style.css -o src/dist/style.css",
    "min": "postcss src/dist/style.css -o src/dist/styles.min.css --use autoprefixer cssnano",
    "unused": "npx postcss src/dist/style.css -o src/dist/style.purged.css",
    "lint": "stylelint ./src/styles/*.scss --fix && stylelint ./src/styles/*.scss",
    "prettier": "prettier --write src/styles/*.scss && prettier --write \"src/dist/style.css\"",
    "prod": "npm run lint && npm run compile && npm run prefix && npm run unused && npm run prettier && postcss src/dist/style.css -o src/dist/style.min.css"
  },
  "devDependencies": {
    "@babel/core": "^7.23.5",
    "@babel/preset-env": "^7.23.5",
    "@fullhuman/postcss-purgecss": "^5.0.0",
    "autoprefixer": "^10.4.17",
    "clean-css-cli": "^5.6.3",
    "cssnano": "^6.0.3",
    "html-validate": "^8.7.4",
    "jest": "29.7",
    "jest-junit": "^13.2.0",
    "jsdom": "^19.0.0",
    "parse-gitignore": "^2.0.0",
    "postcss": "^8.4.33",
    "postcss-cli": "^11.0.0",
    "prettier": "^3.1.1",
    "purify-css": "^1.2.5",
    "sass": "^1.89.1",
    "stylelint": "^16.20.0",
    "stylelint-config-recommended-scss": "^15.0.1",
    "stylelint-config-standard": "^35.0.0",
    "stylelint-scss": "^6.12.0"
  },
  "jest-junit": {
    "suiteName": "junit test results",
    "outputDirectory": ".",
    "outputName": "junit.xml"
  }
}
